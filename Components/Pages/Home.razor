@page "/"
@inject IWebHostEnvironment Env

<PageTitle>Home — .NET on Clever Cloud</PageTitle>

<div class="cc-hero">
    <div class="cc-badge">
        <span class="cc-dot"></span>
        Live on Clever Cloud
    </div>
    <h1 class="cc-title">
        <span class="cc-dotnet">.NET</span> + <span class="cc-cc">Clever Cloud</span>
    </h1>
    <p class="cc-subtitle">A Blazor Server app running in production</p>
</div>

<div class="cc-card">
    <div class="cc-card-title">Runtime Info</div>
    <div class="cc-info-grid">
        <div class="cc-info-item">
            <div class="cc-info-label">Framework</div>
            <div class="cc-info-value">.NET @Environment.Version.ToString(2)</div>
        </div>
        <div class="cc-info-item">
            <div class="cc-info-label">Environment</div>
            <div class="cc-info-value">@Env.EnvironmentName</div>
        </div>
        <div class="cc-info-item">
            <div class="cc-info-label">App Type</div>
            <div class="cc-info-value">Blazor Server</div>
        </div>
        <div class="cc-info-item">
            <div class="cc-info-label">Platform</div>
            <div class="cc-info-value">@System.Runtime.InteropServices.RuntimeInformation.OSDescription.Split(' ')[0]</div>
        </div>
    </div>
</div>

<div class="cc-card">
    <div class="cc-card-title">Try the demo</div>
    <a class="cc-link-btn" href="counter">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
            <polyline points="17 6 23 6 23 12"/>
        </svg>
        Interactive Counter
    </a>
</div>

<div class="cc-card">
    <div class="cc-card-title">Deploy your own</div>
    <a class="cc-cta" href="https://www.clever-cloud.com" target="_blank" rel="noopener noreferrer">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
        Try Clever Cloud
    </a>
</div>

<style>
    .cc-hero {
        text-align: center;
        margin-bottom: 28px;
        padding: 8px 0 4px;
    }
    .cc-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,90,31,0.1);
        border: 1px solid rgba(255,90,31,0.22);
        border-radius: 99px;
        color: #FF5A1F;
        font-size: 13px;
        font-weight: 500;
        padding: 6px 16px;
        margin-bottom: 16px;
    }
    .cc-dot {
        width: 7px;
        height: 7px;
        background: #FF5A1F;
        border-radius: 50%;
        animation: cc-pulse 2s ease infinite;
        display: inline-block;
    }
    @@keyframes cc-pulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
    .cc-title {
        font-size: 36px;
        font-weight: 700;
        color: #E6E8F0;
        margin-bottom: 8px;
    }
    .cc-dotnet { color: #FF5A1F; }
    .cc-cc { color: #22c55e; }
    .cc-subtitle { color: #4E5468; font-size: 15px; margin: 0; }
    .cc-card {
        background: #0C0E13;
        border: 1px solid #1A1D26;
        border-radius: 16px;
        padding: 22px 24px;
        margin-bottom: 14px;
    }
    .cc-card-title {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #4E5468;
        margin-bottom: 14px;
    }
    .cc-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }
    .cc-info-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid #1A1D26;
        border-radius: 10px;
        padding: 12px 14px;
    }
    .cc-info-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #4E5468;
        margin-bottom: 4px;
    }
    .cc-info-value {
        font-size: 14px;
        color: #E6E8F0;
        font-family: 'DM Mono', monospace;
    }
    .cc-cta, .cc-link-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        padding: 11px 18px;
        text-decoration: none;
        transition: all 0.15s;
    }
    .cc-cta {
        background: #FF5A1F;
        color: #07080C;
    }
    .cc-cta:hover {
        background: #E8491A;
        transform: translateY(-1px);
        box-shadow: 0 4px 20px rgba(255,90,31,0.25);
        color: #07080C;
    }
    .cc-link-btn {
        background: rgba(255,90,31,0.08);
        color: #FF5A1F;
        border: 1px solid rgba(255,90,31,0.22);
    }
    .cc-link-btn:hover {
        background: rgba(255,90,31,0.15);
        transform: translateY(-1px);
        color: #FF5A1F;
    }
    @@media (max-width: 480px) { .cc-info-grid { grid-template-columns: 1fr; } }
</style>
